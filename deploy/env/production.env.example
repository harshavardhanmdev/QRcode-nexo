# qrdock production environment — copy to <repo root>/.env.production on the
# server and fill in real values. NEVER commit the filled file.

# ---- ports (pick free ones via: bash deploy/port-audit.sh) ----
WEB_PORT=4620
API_PORT=4621

# ---- public identity ----
NEXT_PUBLIC_SITE_URL=https://qr.theslpl.in
SITE_ORIGIN=https://qr.theslpl.in

# ---- secrets: generate each with  openssl rand -base64 32  ----
SESSION_PEPPER=REPLACE_ME_32_RANDOM_BYTES
IP_HASH_MASTER=REPLACE_ME_32_RANDOM_BYTES

# ---- database ----
DATABASE_PATH=server/data/qrdock.db

# ---- Google sign-in (optional; button hides until set — docs/05) ----
#GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
#GOOGLE_CLIENT_SECRET=xxxxxxxx

# ---- contact-form email (optional; messages stored in DB regardless — docs/09) ----
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=saradapublications18@gmail.com
#SMTP_PASS=your-gmail-app-password
#SMTP_FROM=saradapublications18@gmail.com
CONTACT_TO=saradapublications18@gmail.com

# ---- ads (optional; slots stay hidden until BOTH set — docs/07) ----
#NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
#NEXT_PUBLIC_ADSENSE_SLOT=1234567890

# ---- Search Console HTML-tag verification (optional — docs/06) ----
#NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=paste-content-value-from-google

TRUST_PROXY=1
NODE_ENV=production
